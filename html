            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-weight: 500;
            letter-spacing: 0.2px;
            transition: 0.2s;
        }
        .price-item:hover .wa-badge {
            background: #25D36620;
            border-color: #25D36640;
        }
        .wa-badge i {
            font-size: 0.7rem;
            color: #25D366;
        }
