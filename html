    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0b1424;
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            padding: 2rem 1.25rem;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            max-width: 1200px;
            width: 100%;
        }

        /* ===== HEADER ===== */
        .header {
            text-align: center;
            margin-bottom: 2.8rem;
        }

        .header .icon {
            background: linear-gradient(145deg, #f6b83e, #d4942a);
            width: 80px;
            height: 80px;
            border-radius: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2.6rem;
            color: #0b1424;
            box-shadow: 0 16px 40px -10px rgba(214, 148, 42, 0.4);
            margin-bottom: 1rem;
        }

        .header h1 {
            font-size: 2.8rem;
            font-weight: 900;
            color: #fff;
            letter-spacing: -0.5px;
        }

        .header h1 span {
            background: linear-gradient(135deg, #f6b83e, #d4942a);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .header .sub {
            color: #7e93ae;
            font-size: 1rem;
            margin-top: 0.5rem;
            font-weight: 400;
        }

        .header .badge {
            display: inline-block;
            background: rgba(246, 184, 62, 0.12);
            border: 1px solid rgba(246, 184, 62, 0.2);
            color: #f6b83e;
            padding: 0.4rem 1.6rem;
            border-radius: 60px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 0.8rem;
        }

        .header .badge i {
            margin-right: 6px;
        }

        /* ===== GRID HARGA ===== */
        .price-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
            gap: 1.1rem;
        }

        .price-card {
            background: #132237;
            border: 1px solid #243c54;
            border-radius: 24px;
            padding: 1.5rem 0.8rem;
            text-align: center;
            cursor: pointer;
            transition: 0.25s ease;
            text-decoration: none;
            color: #fff;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            position: relative;
            overflow: hidden;
        }

        .price-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(246, 184, 62, 0.06), transparent 70%);
            opacity: 0;
            transition: 0.3s;
            pointer-events: none;
        }

        .price-card:hover {
            border-color: #f6b83e;
            transform: translateY(-6px);
            box-shadow: 0 20px 40px -12px rgba(246, 184, 62, 0.15);
            background: #182d42;
        }

        .price-card:hover::after {
            opacity: 1;
        }

        .price-card .fee-label {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #6f8aaa;
            background: #1b3045;
            padding: 0.15rem 1rem;
            border-radius: 40px;
            display: inline-block;
        }

        .price-card .fee-label i {
            margin-right: 4px;
            font-size: 0.55rem;
            color: #f6b83e;
        }

        .price-card .nominal {
            font-size: 2.2rem;
            font-weight: 900;
            color: #fff;
            line-height: 1.2;
        }

        .price-card .nominal small {
            font-size: 1rem;
            font-weight: 500;
            color: #6f8aaa;
            margin-left: 2px;
        }

        .price-card .price-tag {
            font-size: 1rem;
            font-weight: 600;
            color: #f6b83e;
            background: rgba(246, 184, 62, 0.08);
            padding: 0.2rem 1.2rem;
            border-radius: 40px;
            border: 1px solid rgba(246, 184, 62, 0.1);
        }

        .price-card .price-tag i {
            margin-right: 5px;
            font-size: 0.7rem;
        }

        .price-card .wa-btn {
            font-size: 0.7rem;
            color: #4a6b8a;
            margin-top: 6px;
            background: #1a2f44;
            padding: 0.2rem 1rem;
            border-radius: 40px;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            border: 1px solid transparent;
        }

        .price-card:hover .wa-btn {
            color: #25D366;
            background: #102a35;
            border-color: #25D36630;
        }

        .price-card .wa-btn i {
            color: #25D366;
            font-size: 0.7rem;
        }

        /* ===== FOOTER ===== */
        .footer {
            margin-top: 3rem;
            text-align: center;
            color: #4a6b8a;
            font-size: 0.85rem;
            border-top: 1px solid #1a2f44;
            padding-top: 1.8rem;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 1.5rem;
        }

        .footer span i {
            color: #f6b83e;
            margin-right: 5px;
        }

        .footer .trust {
            color: #6f8aaa;
            font-weight: 500;
        }

        .footer .trust i {
            color: #25D366;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 600px) {
            .header h1 {
                font-size: 2rem;
            }
            .price-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.8rem;
            }
            .price-card {
                padding: 1.1rem 0.3rem;
                border-radius: 18px;
            }
            .price-card .nominal {
                font-size: 1.7rem;
            }
        }

        @media (max-width: 400px) {
            .price-grid {
                grid-template-columns: 1fr 1fr;
                gap: 0.6rem;
            }
            .price-card {
                padding: 0.9rem 0.2rem;
            }
            .price-card .nominal {
                font-size: 1.4rem;
            }
            .price-card .price-tag {
                font-size: 0.8rem;
                padding: 0.1rem 0.8rem;
            }
        }

        /* ===== ANIMASI ===== */
        .price-card {
            animation: fadeUp 0.4s ease forwards;
            opacity: 0;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .price-card:nth-child(1) { animation-delay: 0.02s; }
        .price-card:nth-child(2) { animation-delay: 0.04s; }
        .price-card:nth-child(3) { animation-delay: 0.06s; }
        .price-card:nth-child(4) { animation-delay: 0.08s; }
        .price-card:nth-child(5) { animation-delay: 0.10s; }
        .price-card:nth-child(6) { animation-delay: 0.12s; }
        .price-card:nth-child(7) { animation-delay: 0.14s; }
        .price-card:nth-child(8) { animation-delay: 0.16s; }
        .price-card:nth-child(9) { animation-delay: 0.18s; }
        .price-card:nth-child(10) { animation-delay: 0.20s; }
        .price-card:nth-child(11) { animation-delay: 0.22s; }
    </style>
