<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JOKO FT ANTI KALAH</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400,500,600,700,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0e1a2b;
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem 1.25rem;
        }

        .container {
            max-width: 1100px;
            width: 100%;
        }

        /* header */
        .header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .header .logo-icon {
            background: linear-gradient(145deg, #f5b042, #d48d2b);
            width: 72px;
            height: 72px;
            border-radius: 24px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            color: #0e1a2b;
            box-shadow: 0 12px 30px -8px rgba(212, 141, 43, 0.35);
            margin-bottom: 1rem;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: -0.5px;
        }

        .header h1 span {
            background: linear-gradient(135deg, #f5b042, #d48d2b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .header p {
            color: #8899b0;
            font-size: 1rem;
            margin-top: 0.5rem;
            font-weight: 400;
            letter-spacing: 0.3px;
        }

        .header .badge {
            display: inline-block;
            background: rgba(245, 176, 66, 0.12);
            border: 1px solid rgba(245, 176, 66, 0.25);
            color: #f5b042;
            padding: 0.4rem 1.4rem;
            border-radius: 60px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 0.8rem;
        }

        /* grid tombol */
        .btn-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
            gap: 1.2rem;
            margin-top: 0.5rem;
        }

        .btn-order {
            background: #162433;
            border: 1px solid #243b4f;
            border-radius: 24px;
            padding: 1.4rem 0.8rem;
            text-align: center;
            cursor: pointer;
            transition: 0.25s ease;
            text-decoration: none;
            color: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            position: relative;
            overflow: hidden;
        }

        .btn-order::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(245, 176, 66, 0.05), transparent);
            opacity: 0;
            transition: 0.3s;
        }

        .btn-order:hover {
            border-color: #f5b042;
            transform: translateY(-5px);
            box-shadow: 0 18px 35px -12px rgba(245, 176, 66, 0.15);
            background: #1a2b3d;
        }

        .btn-order:hover::before {
            opacity: 1;
        }

        .btn-order .fee {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #7a92ad;
            background: #1f3345;
            padding: 0.15rem 0.9rem;
            border-radius: 40px;
            display: inline-block;
        }

        .btn-order .fee i {
            margin-right: 4px;
            font-size: 0.6rem;
            color: #f5b042;
        }

        .btn-order .amount {
            font-size: 2rem;
            font-weight: 800;
            color: #ffffff;
            line-height: 1.2;
        }

        .btn-order .amount small {
            font-size: 1rem;
            font-weight: 500;
            color: #7a92ad;
            margin-left: 2px;
        }

        .btn-order .price-tag {
            font-size: 0.95rem;
            font-weight: 600;
            color: #f5b042;
            background: rgba(245, 176, 66, 0.08);
            padding: 0.2rem 1rem;
            border-radius: 40px;
            border: 1px solid rgba(245, 176, 66, 0.12);
        }

        .btn-order .price-tag i {
            margin-right: 5px;
            font-size: 0.7rem;
        }

        .btn-order .wa-hint {
            font-size: 0.7rem;
            color: #4d6a85;
            margin-top: 4px;
            display: flex;
            align-items: center;
            gap: 4px;
            background: #1f3345;
            padding: 0.15rem 0.9rem;
            border-radius: 40px;
            transition: 0.2s;
        }

        .btn-order:hover .wa-hint {
            color: #25D366;
            background: #1a2f3a;
            border-color: #25D36630;
        }

        .btn-order .wa-hint i {
            color: #25D366;
            font-size: 0.7rem;
        }

        /* footer */
        .footer {
            margin-top: 3rem;
            text-align: center;
            color: #4d6a85;
            font-size: 0.85rem;
            border-top: 1px solid #1f3345;
            padding-top: 1.8rem;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 1.5rem;
        }

        .footer span i {
            color: #f5b042;
            margin-right: 5px;
        }

        .footer .trust {
            color: #7a92ad;
            font-weight: 500;
        }

        .footer .trust i {
            color: #25D366;
        }

        /* respon */
        @media (max-width: 600px) {
            .header h1 {
                font-size: 2rem;
            }
            .btn-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.9rem;
            }
            .btn-order {
                padding: 1.1rem 0.4rem;
            }
            .btn-order .amount {
                font-size: 1.6rem;
            }
        }

        @media (max-width: 400px) {
            .btn-grid {
                grid-template-columns: 1fr 1fr;
                gap: 0.7rem;
            }
            .btn-order {
                padding: 0.9rem 0.2rem;
                border-radius: 18px;
            }
            .btn-order .amount {
                font-size: 1.4rem;
            }
        }

        /* animasi muncul */
        .btn-order {
            animation: fadeUp 0.4s ease forwards;
            opacity: 0;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-order:nth-child(1) { animation-delay: 0.02s; }
        .btn-order:nth-child(2) { animation-delay: 0.04s; }
        .btn-order:nth-child(3) { animation-delay: 0.06s; }
        .btn-order:nth-child(4) { animation-delay: 0.08s; }
        .btn-order:nth-child(5) { animation-delay: 0.10s; }
        .btn-order:nth-child(6) { animation-delay: 0.12s; }
        .btn-order:nth-child(7) { animation-delay: 0.14s; }
        .btn-order:nth-child(8) { animation-delay: 0.16s; }
        .btn-order:nth-child(9) { animation-delay: 0.18s; }
        .btn-order:nth-child(10) { animation-delay: 0.20s; }
        .btn-order:nth-child(11) { animation-delay: 0.22s; }
    </style>
